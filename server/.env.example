# Local MongoDB:
# MONGODB_URI=mongodb://127.0.0.1:27017/sparkhive
#
# MongoDB Atlas example:
# MONGODB_URI=mongodb+srv://<USERNAME>:<PASSWORD>@<CLUSTER>.mongodb.net/sparkhive?retryWrites=true&w=majority&appName=SparkHive
MONGODB_URI=
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
API_PUBLIC_URL=http://localhost:5000
REQUIRE_DB=false
MONGODB_SERVER_SELECTION_TIMEOUT_MS=10000
MONGODB_SOCKET_TIMEOUT_MS=45000
MONGODB_MAX_POOL_SIZE=20
MONGODB_MIN_POOL_SIZE=2

# JWT Admin Auth (required for CMS)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Seed admin user (npm run seed:admin)
ADMIN_EMAIL=admin@sparkhive.com
ADMIN_PASSWORD=SparkHive@2025
ADMIN_NAME=SparkHive Admin

# Mailchimp (optional)
MAILCHIMP_API_KEY=
MAILCHIMP_SERVER_PREFIX=us21
MAILCHIMP_AUDIENCE_ID=

# Calendly embed URL (optional — shown on Book Consultation page)
CALENDLY_URL=https://calendly.com/your-link/30min

# Analytics (optional — passed to frontend via /api/config/public)
GA_MEASUREMENT_ID=
META_PIXEL_ID=
WHATSAPP_NUMBER=919810494571
